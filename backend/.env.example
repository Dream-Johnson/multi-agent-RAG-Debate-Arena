# Copy this file to .env and fill in real values. Never commit .env itself.

# Claude (debate agents) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (embeddings) — https://dashboard.voyageai.com/
VOYAGE_API_KEY=pa-...

# Pinecone (vector database) — https://app.pinecone.io/
PINECONE_API_KEY=pcsk_...

# Simple password gate for the app itself (your choice, not from any provider)
APP_PASSWORD=change-me
